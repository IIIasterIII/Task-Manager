# Client ID from Google Cloud Console (API & Services) -> Example: 123456789-abc123.apps.googleusercontent.com
GOOGLE_CLIENT_ID=

# Client Secret from Google Cloud Console -> Example: GOCSPX-your_secret_key_here
GOOGLE_CLIENT_SECRET=

# URL where Google redirects users after authentication (This exact address must be registered in Google Cloud Console under "Authorized redirect URIs") -> Example: http://localhost:8000/auth/google/callback
REDIRECT_URL=

# Main application secret key for data signing and token encryption -> Example: use a long random hex string
SECRET_KEY=

# The destination page on the frontend after a successful Google authentication -> Example: http://localhost:3000/app
FRONTEND_URL=

# Base URL of your Frontend application (required for CORS policy and cross-origin redirects) -> Example: http://localhost:3000
FRONTEND_URL_CORS=

# Connection string for your MySQL database (using aiomysql driver for async support) -> Example: mysql+aiomysql://user:password@localhost:3306/db
DATABASE_URL=

# Connection string for your Redis instance (used for caching, sessions, and rate limiting) -> Example: redis://localhost:6379
REDIS_URL=